pkgname=raveos-tools
pkgver=1.0.0
pkgrel=1
arch=('any')
url="https://git.rp1.hu/RaveOS/RaveOS-PKGBUILD"
license=('custom')
depends=('pacman' 'flatpak')
source=()
sha256sums=()

BUILDDIR="${startdir}/build"
PKGDEST="${startdir}/build"
SRCDEST="${startdir}/build"
SRCPKGDEST="${startdir}/build"
LOGDEST="${startdir}/build"

package() {
  install -Dm755 "${startdir}/rave" \
    "${pkgdir}/usr/bin/rave"

  install -Dm644 "${startdir}/rave-completion" \
    "${pkgdir}/usr/share/bash-completion/completions/rave"
}
