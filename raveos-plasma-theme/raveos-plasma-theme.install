post_install() {
    if [[ -x /usr/lib/raveos-plasma-theme/auto-apply.sh ]]; then
        /usr/lib/raveos-plasma-theme/auto-apply.sh || true
    fi
}

post_upgrade() {
    if [[ -x /usr/lib/raveos-plasma-theme/auto-apply.sh ]]; then
        /usr/lib/raveos-plasma-theme/auto-apply.sh || true
    fi
}
